{
  "name": "prompt-gateway",
  "version": "0.0.1",
  "description": "Local LLM gateway for capturing Claude Code prompt payloads.",
  "type": "module",
  "packageManager": "pnpm@10.7.1",
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "prompt-gateway": "./dist/cli.js"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "scripts": {
    "format": "biome format --write .",
    "check": "biome check .",
    "build": "tsup",
    "commitlint": "commitlint --edit",
    "dev": "tsx src/cli.ts",
    "lint-staged": "lint-staged",
    "pack:dry": "pnpm pack --pack-destination ./.artifacts",
    "prepack": "pnpm build",
    "prepare": "husky",
    "start": "node dist/cli.js",
    "test": "tsx --test test/*.test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
